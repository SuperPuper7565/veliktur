<%- include('partials/header', { title: title }) %>

<section class="hero" id="hero">
  <div class="container hero__layout">
    <div class="hero__content">
      <p class="hero__location">
        <span class="hero__location-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z" fill="currentColor"/>
          </svg>
        </span>
        ПЕРМЬ
      </p>
      <h1 class="hero__title">ВеликТур</h1>
      <p class="hero__subtitle">
        Велосипеды для города, троп и длинных маршрутов.<br />
        Подберем модель под ваш стиль катания и доставим по Перми уже сегодня.
      </p>
      <a class="btn hero__cta" href="#catalog">Смотреть каталог</a>
      <div class="hero__contacts">
        <a class="hero__phone" href="tel:+79001234567">+7 (900) 123-45-67</a>
        <p class="hero__phone-note">Круглосуточный прием заказов</p>
      </div>
    </div>

    <div class="hero__media">
      <div class="hero__media-bg">
        <img src="/images/gorniy_velosiped_na_doroge.png" alt="Велосипед VelikTur" />
      </div>
    </div>
  </div>

  <div class="container hero__info" aria-label="Информация о магазине">
    <div class="info-bar__inner">
      <article class="info-bar__item">
        <a class="info-bar__icon info-bar__icon-link" href="#contact" aria-label="Перейти к карте">
          <svg viewBox="0 0 24 24" role="img">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z" fill="currentColor"/>
          </svg>
        </a>
        <div>
          <p class="info-bar__label">Наш магазин</p>
          <p class="info-bar__value">ул. Ленина, 10</p>
        </div>
      </article>

      <article class="info-bar__item">
        <span class="info-bar__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="img">
            <circle cx="12" cy="12" r="8.5" fill="none" stroke="currentColor" stroke-width="1.8"/>
            <path d="M12 7.6v4.7l3.1 1.9" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <div>
          <p class="info-bar__label">Время работы</p>
          <p class="info-bar__value">10:00 - 21:00</p>
        </div>
      </article>

      <article class="info-bar__social">
        <p class="info-bar__label">Наши соцсети:</p>
        <div class="info-bar__social-list">
          <a class="info-bar__social-btn" href="#" aria-label="ВКонтакте">
            <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
              <path d="M4.76 7.57c.13 6.26 3.26 10.03 8.75 10.03h.31v-3.58c2.02.21 3.55 1.68 4.16 3.58h2.86c-.78-2.83-2.83-4.4-4.11-5 .68-.39 3.01-2.06 3.24-5.03h-2.6c-.3 2.41-2.44 4.08-3.55 4.28V7.57h-2.6v7.49c-1.13-.28-3.57-2.05-3.63-7.49H4.76z" fill="currentColor"/>
            </svg>
          </a>
          <a class="info-bar__social-btn" href="#" aria-label="YouTube">
            <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
              <path d="M21.58 7.2a2.7 2.7 0 0 0-1.9-1.9C18.1 4.9 12 4.9 12 4.9s-6.1 0-7.68.4a2.7 2.7 0 0 0-1.9 1.9C2 8.78 2 12 2 12s0 3.22.42 4.8a2.7 2.7 0 0 0 1.9 1.9c1.58.4 7.68.4 7.68.4s6.1 0 7.68-.4a2.7 2.7 0 0 0 1.9-1.9c.42-1.58.42-4.8.42-4.8s0-3.22-.42-4.8zM10 15.3V8.7L15.7 12 10 15.3z" fill="currentColor"/>
            </svg>
          </a>
          <a class="info-bar__social-btn" href="#" aria-label="Telegram">
            <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
              <path d="M20.67 4.34 3.91 10.8c-1.14.46-1.13 1.1-.21 1.38l4.3 1.34 1.66 5.08c.2.56.1.79.7.79.46 0 .66-.21.92-.46l2.08-2.02 4.33 3.2c.8.44 1.37.21 1.57-.74l2.85-13.44c.29-1.17-.45-1.7-1.44-1.26zM8.68 13.22l9.98-6.29c.5-.3.96-.14.58.19l-8.55 7.72-.33 3.56-1.68-5.18z" fill="currentColor"/>
            </svg>
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<section class="stats" aria-label="Статистика магазина">
  <div class="container stats__grid">
    <article class="stats__item">
      <p class="stats__value">2015</p>
      <p class="stats__label">Работаем с 2015 года</p>
    </article>

    <article class="stats__item">
      <p class="stats__value">2340+</p>
      <p class="stats__label">Довольных клиентов</p>
    </article>

    <article class="stats__item">
      <p class="stats__value">450+</p>
      <p class="stats__label">Живых отзывов</p>
    </article>

    <article class="stats__item stats__item--highlight">
      <p class="stats__value">14 дней</p>
      <p class="stats__label">Гарантия возврата</p>
    </article>
  </div>
</section>

<section class="section section-muted" id="catalog">
  <div class="container">
    <div class="section-head">
      <h2>Выбор стиля и каталог велосипедов</h2>
      <p>Выберите категорию, найдите модель по названию и отфильтруйте велосипеды по характеристикам.</p>
    </div>

    <% const brands = [...new Set(products.map((item) => item.brand))].sort(); %>
    <% const wheels = [...new Set(products.map((item) => item.wheel))].sort((a, b) => parseFloat(a) - parseFloat(b)); %>
    <% const speeds = [...new Set(products.map((item) => item.speed))].sort((a, b) => Number(a) - Number(b)); %>
    <% const frames = [...new Set(products.map((item) => item.frame))].sort(); %>
    <% const brakeTypes = [...new Set(products.map((item) => item.brakeType))].sort(); %>

    <div class="category-buttons" id="categoryButtons">
      <button class="category-btn is-active" type="button" data-category="all">Все</button>
      <button class="category-btn" type="button" data-category="kids">Детские</button>
      <button class="category-btn" type="button" data-category="city">Городские</button>
      <button class="category-btn" type="button" data-category="mountain">Горные</button>
      <button class="category-btn" type="button" data-category="hybrid">Гибридные</button>
    </div>

    <div class="search-sort-row">
      <div>
        <label for="searchInput" class="sr-only">Поиск по названию</label>
        <input id="searchInput" type="text" placeholder="Поиск велосипеда по названию" />
      </div>
      <div class="price-control">
        <label for="priceRange">Цена до: <span id="priceValue"></span></label>
        <input id="priceRange" type="range" min="0" step="1000" />
      </div>
    </div>

    <div class="category-advanced" id="categoryAdvanced">
      <div class="category-advanced-copy">
        <h3 id="categoryAdvancedTitle">Подберем велосипед под ваши задачи</h3>
        <p id="categoryAdvancedDescription">Выберите категорию выше, и мы покажем подходящие фильтры.</p>
      </div>
      <div class="category-advanced-controls">
        <div class="advanced-group" id="genderButtons"></div>
        <span class="advanced-separator" id="advancedSeparator" aria-hidden="true">|</span>
        <div class="advanced-group" id="ageButtons"></div>
      </div>
    </div>

    <div class="spec-filters-row">
      <select id="brandFilter">
        <option value="all">Бренд</option>
        <% brands.forEach((brand) => { %>
        <option value="<%= brand %>"><%= brand %></option>
        <% }) %>
      </select>

      <select id="wheelFilter">
        <option value="all">Диаметр колес</option>
        <% wheels.forEach((wheel) => { %>
        <option value="<%= wheel %>"><%= wheel %></option>
        <% }) %>
      </select>

      <select id="speedsFilter">
        <option value="all">Кол-во скоростей</option>
        <% speeds.forEach((speed) => { %>
        <option value="<%= speed %>"><%= speed %></option>
        <% }) %>
      </select>

      <select id="frameFilter">
        <option value="all">Материал рамы</option>
        <% frames.forEach((frame) => { %>
        <option value="<%= frame %>"><%= frame %></option>
        <% }) %>
      </select>

      <select id="brakeFilter">
        <option value="all">Тип тормоза</option>
        <% brakeTypes.forEach((brakeType) => { %>
        <option value="<%= brakeType %>"><%= brakeType %></option>
        <% }) %>
      </select>
    </div>

    <p class="result-count" id="resultCount">Найдено: <%= products.length %></p>

    <div class="catalog-grid" id="catalogGrid">
      <% products.forEach((product) => { %>
      <%- include('partials/product-card', { product: product }) %>
      <% }) %>
    </div>

    <div class="catalog-pagination" id="catalogPagination">
      <button class="category-btn" type="button" id="prevPageBtn">Назад</button>
      <p class="pagination-info" id="paginationInfo">Страница 1 из 1</p>
      <button class="category-btn" type="button" id="nextPageBtn">Вперед</button>
    </div>
  </div>
</section>

<section class="section" id="sizes">
  <div class="container">
    <div class="section-head">
      <h2>Как выбрать размер?</h2>
      <p>Таблица автоматически обновляется по выбранной категории.</p>
    </div>
    <div class="table-wrap">
      <table id="sizeGuideTable">
        <thead id="sizeGuideHead">
          <tr>
            <th>Возраст</th>
            <th>Рост (см)</th>
            <th>Диаметр колес (″)</th>
          </tr>
        </thead>
        <tbody id="sizeGuideBody">
          <tr><td>2-4 года</td><td>85-105</td><td>12" / 14"</td></tr>
          <tr><td>4-6 лет</td><td>105-120</td><td>16"</td></tr>
          <tr><td>6-9 лет</td><td>120-135</td><td>20"</td></tr>
          <tr><td>9-12 лет</td><td>135-150</td><td>24"</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section section-muted" id="bestsellers">
  <div class="container">
    <div class="section-head">
      <h2>Бестселлеры</h2>
      <p>Модели, которые покупают чаще всего.</p>
    </div>
    <div class="best-grid">
      <% products.filter((item) => item.isBestSeller).slice(0, 3).forEach((item) => { %>
      <article
        class="best-card"
        data-id="<%= item.id %>"
        data-product-card
        tabindex="0"
        role="button"
        aria-label="Открыть карточку товара <%= item.name %>"
      >
        <img src="<%= item.image %>" alt="<%= item.name %>" />
        <div class="best-card__body">
          <p class="best-card__brand"><%= item.brand %> • <%= item.categoryName %></p>
          <h3><%= item.name %></h3>
          <p class="best-card__meta"><%= item.frame %> • <%= item.wheel %> • <%= item.brakeType %></p>
          <p class="best-card__price"><%= item.price.toLocaleString('ru-RU') %> ₽</p>
          <div class="product-actions" data-product-actions data-product-id="<%= item.id %>" data-variant="best">
            <button class="btn" type="button" data-action="add-to-cart" data-product-id="<%= item.id %>">
              В корзину
            </button>
          </div>
        </div>
      </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="section" id="gallery">
  <div class="container">
    <div class="section-head">
      <h2>Катаемся в Перми</h2>
    </div>

    <div class="gallery-carousel">
      <button class="gallery-carousel__arrow" type="button" id="galleryPrevBtn" aria-label="Предыдущая фотография">
        <span aria-hidden="true">‹</span>
      </button>

      <div class="gallery-carousel__viewport">
        <div class="gallery-carousel__track" id="galleryTrack">
          <figure class="gallery-carousel__slide">
            <img src="/images/perm-ride-01.png" alt="Катание по Перми - фото 1" />
          </figure>
          <figure class="gallery-carousel__slide">
            <img src="/images/perm-ride-02.png" alt="Катание по Перми - фото 2" />
          </figure>
          <figure class="gallery-carousel__slide">
            <img src="/images/perm-ride-03.png" alt="Катание по Перми - фото 3" />
          </figure>
          <figure class="gallery-carousel__slide">
            <img src="/images/perm-ride-04.png" alt="Катание по Перми - фото 4" />
          </figure>
          <figure class="gallery-carousel__slide">
            <img src="/images/perm-ride-05.png" alt="Катание по Перми - фото 5" />
          </figure>
        </div>
      </div>

      <button class="gallery-carousel__arrow" type="button" id="galleryNextBtn" aria-label="Следующая фотография">
        <span aria-hidden="true">›</span>
      </button>
    </div>

    <div class="gallery-carousel__footer">
      <p class="gallery-carousel__caption">Показываем, как выглядят городские велопрогулки и тест-драйвы вместе с нашей командой.</p>
      <p class="gallery-carousel__counter" id="galleryCounter">1 / 5</p>
    </div>
  </div>
</section>

<section class="section section-muted" id="benefits">
  <div class="container">
    <div class="section-head">
      <h2>Что говорят покупатели</h2>
    </div>
    <div class="reviews-grid">
      <article class="review-card">
        <div class="review-card__top">
          <p class="review-card__name">Анна Петрова</p>
          <p class="review-card__rating">★★★★★</p>
        </div>
        <p class="review-card__text">
          Очень помогли с подбором размера и быстро доставили. Велосипед приехал уже настроенным, кататься начала в тот же день.
        </p>
      </article>

      <article class="review-card">
        <div class="review-card__top">
          <p class="review-card__name">Илья Смирнов</p>
          <p class="review-card__rating">★★★★★</p>
        </div>
        <p class="review-card__text">
          Заказывал горный велосипед для поездок по лесу. Консультант подробно объяснил разницу между моделями, покупкой доволен.
        </p>
      </article>

      <article class="review-card">
        <div class="review-card__top">
          <p class="review-card__name">Екатерина Власова</p>
          <p class="review-card__rating">★★★★☆</p>
        </div>
        <p class="review-card__text">
          Удобный сайт, понятные фильтры и вежливая поддержка. Выбрала городской велосипед, вживую он даже лучше, чем на фото.
        </p>
      </article>
    </div>
  </div>
</section>

<section class="section" id="contact">
  <div class="container contact-grid">
    <div class="contact-info">
      <div class="section-head">
        <h2>Быстрая доставка по Перми</h2>
      </div>
      <div class="delivery-points">
        <article class="delivery-item">
          <span class="delivery-item__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M3 7.2A2.2 2.2 0 0 1 5.2 5h9.1a2.2 2.2 0 0 1 2.2 2.2v2.1h1.7c.7 0 1.35.34 1.76.92l1.7 2.42c.22.31.34.67.34 1.05v2.08a1.2 1.2 0 0 1-1.2 1.2h-.98a2.9 2.9 0 0 1-5.64 0H9.34a2.9 2.9 0 0 1-5.64 0H2.9a1.2 1.2 0 0 1-1.2-1.2V8.4c0-.66.54-1.2 1.2-1.2h.1zm4.02 10.06a1.3 1.3 0 1 0 0 2.6 1.3 1.3 0 0 0 0-2.6zm10.36 0a1.3 1.3 0 1 0 0 2.6 1.3 1.3 0 0 0 0-2.6z" fill="currentColor"/>
            </svg>
          </span>
          <div>
            <h3 class="delivery-item__title">Доставка до двери</h3>
            <p class="delivery-item__text">Привезем ваш велосипед в любую точку города в течение 24 часов.</p>
          </div>
        </article>

        <article class="delivery-item">
          <span class="delivery-item__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M7.2 6.2A2.2 2.2 0 0 1 9.4 4h5.2a2.2 2.2 0 0 1 2.2 2.2V8h1.1A1.1 1.1 0 0 1 19 9.1v8.7A2.2 2.2 0 0 1 16.8 20H7.2A2.2 2.2 0 0 1 5 17.8V9.1A1.1 1.1 0 0 1 6.1 8h1.1V6.2zm1.8 0V8h6V6.2a.4.4 0 0 0-.4-.4H9.4a.4.4 0 0 0-.4.4z" fill="currentColor"/>
            </svg>
          </span>
          <div>
            <h3 class="delivery-item__title">Самовывоз сегодня</h3>
            <p class="delivery-item__text">Заберите заказ в магазине на ул. Ленина, 10 через 15 минут после оформления.</p>
          </div>
        </article>

        <article class="delivery-item">
          <span class="delivery-item__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M20.7 6.5l-3.2 3.2-1.9-1.9 3.2-3.2a3.2 3.2 0 0 0-4.2.3 3.2 3.2 0 0 0-.78 3.3L6.7 15.4a2.4 2.4 0 1 0 1.9 1.9l7.2-7.2a3.2 3.2 0 0 0 3.3-.78 3.2 3.2 0 0 0 .3-4.2zM5.5 18.5a.9.9 0 1 1 0-1.8.9.9 0 0 1 0 1.8z" fill="currentColor"/>
            </svg>
          </span>
          <div>
            <h3 class="delivery-item__title">Приедет собранным</h3>
            <p class="delivery-item__text">Все велосипеды проходят предпродажную подготовку и настройку механиком.</p>
          </div>
        </article>
      </div>
    </div>

    <div class="map-wrap">
      <iframe
        title="Карта VelikTur - Пермь, ул. Ленина, 10"
        src="https://yandex.ru/map-widget/v1/?ll=56.257102,58.016248&z=16&pt=56.257102,58.016248,pm2rdm"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>

<section class="section section-muted" id="contact-form">
  <div class="container">
    <div class="section-head">
      <h2>Оформить заказ</h2>
      <p>Проверьте товары в корзине и заполните данные для доставки.</p>
    </div>

    <div class="order-layout">
      <section class="order-summary" aria-labelledby="orderSummaryTitle">
        <div class="order-summary__head">
          <h3 id="orderSummaryTitle">Товары из корзины</h3>
          <p>Список синхронизируется с карточками товаров и корзиной в шапке сайта.</p>
        </div>
        <div class="order-summary__list" id="orderCartList"></div>
        <div class="order-summary__footer">
          <span>Итого</span>
          <strong id="orderCartTotal">0 ₽</strong>
        </div>
      </section>

      <div class="order-form-wrap">
        <% if (sent) { %>
        <p class="success-message" id="orderSuccessMessage">
          Спасибо! Заказ оформлен, мы свяжемся с вами в ближайшее время.
        </p>
        <% } %>

        <form class="contact-form order-form" action="/contact" method="post" id="orderForm">
          <input type="hidden" name="orderItems" id="orderItemsInput" />

          <label>
            Имя
            <input type="text" name="name" autocomplete="name" required />
          </label>

          <label>
            Телефон
            <input type="tel" name="phone" autocomplete="tel" required />
          </label>

          <label class="wide">
            Email
            <input type="email" name="email" autocomplete="email" required />
          </label>

          <label class="wide">
            Адрес доставки
            <input
              type="text"
              name="address"
              autocomplete="street-address"
              placeholder="Адрес доставки"
              required
            />
          </label>

          <div class="order-form__submit wide">
            <button class="btn" type="submit" id="orderSubmitBtn">Оформить заказ</button>
            <p class="form-policy">
              Нажимая кнопку, вы соглашаетесь с
              <a href="#">политикой конфиденциальности</a>
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer', { products: products }) %>
